# PR reviewer local/default configuration
# Copy to .env and fill values. Explicit script parameters still win.

# Build/runtime image
IMAGE_NAME=pr-review-bot:latest
PI_VERSION=0.79.1
CONTAINER_NAME=

# Azure DevOps target. Use PR_URL for easiest local usage, or use split values.
PR_URL=
ADO_ORG=
ADO_PROJECT=
ADO_REPO_ID=
PR_ID=
SOURCE_BRANCH=
TARGET_BRANCH=

# Tokens / model
ADO_API_KEY=
# ADO_AUTH_TOKEN is also accepted by the container/posting helper.
ADO_AUTH_TOKEN=
OPENAI_API_KEY=
PI_MODEL=openai/gpt-5.5

# Review behavior
REVIEW_LANGUAGE=English
DRY_RUN=0
FAIL_ON=none
VOTE_WAITING_ON=major
POST_MIN_SEVERITY=major
MAX_DIFF_BYTES=200000
CHUNK_TRIGGER_DIFF_BYTES=
DISABLE_CHUNK_REVIEW=0

# Persistent artifacts
REVIEW_ARTIFACT_VOLUME_NAME=pr-review-bot-artifacts
REVIEW_ARTIFACT_ROOT=/workspace/artifacts
# Optional: set for deterministic output; otherwise generated per run.
REVIEW_RUN_ID=
