# PR reviewer configuration — reference / template only.
#
# This file is NOT auto-loaded by the PowerShell wrappers. It
# documents the env vars the bot understands and their typical
# values. Load it into your shell yourself before running, e.g.:
#
#   bash / zsh:  set -a; source .env; set +a
#   direnv:      place a .envrc that does `dotenv .env`
#   fish:        export (grep -v '^#' .env | xargs)
#   PowerShell:  Get-Content .env | ForEach-Object { ... }  (or any
#                of the community dotenv modules)
#
# Once loaded, ADO_*/OPENAI_*/etc. behave exactly like any other
# process env var: script parameters (--AdoToken, -DryRun, ...) win
# over the env, env wins over defaults baked into the Python
# package. If the file is present at the path passed via
# -EnvFile, run.ps1 also forwards it to ``docker run --env-file``
# so the per-PR container sees the same values.
#
# Run-open-prs.ps1 has no built-in defaults for organization,
# projects, or target branches — set the three ADO_* values below
# before invoking it. Run.ps1 also needs the three ADO_* values
# (or PR_URL) plus ADO_AUTH_TOKEN + OPENAI_API_KEY.

# Azure DevOps target (run-open-prs.ps1 + run.ps1)
ADO_ORGANIZATION=https://dev.azure.com/<your-org>/
ADO_PROJECTS=<proj1>,<proj2>
ADO_TARGET_BRANCHES=main,master,develop,dev

# Per-PR identity (run.ps1 only — used when no PR_URL given)
PR_URL=
ADO_ORG=
ADO_PROJECT=
ADO_REPO_ID=
PR_ID=
SOURCE_BRANCH=
TARGET_BRANCH=

# Auth (at least one of ADO_AUTH_TOKEN / ADO_API_KEY)
ADO_AUTH_TOKEN=
ADO_API_KEY=

# Model
OPENAI_API_KEY=
PI_MODEL=openai/gpt-5.4-mini

# Review behavior
REVIEW_LANGUAGE=English
FAIL_ON=none
VOTE_WAITING_ON=minor
POST_MIN_SEVERITY=minor
DRY_RUN=0

# Optional: path to a Jinja2 template that overrides the default
# comment layout posted to the PR. The bot ships ``comment.md.example``
# at the repo root as a starting point — copy it to ``./comment.md``
# (or wherever) and edit. See ``docs/ado-integration.md`` ("Customizing
# the comment format") for the available placeholders. When unset,
# the bot posts the original hardcoded Markdown layout. A missing
# file is a hard error.
# COMMENT_TEMPLATE_PATH=./comment.md

# Build / runtime
IMAGE_NAME=reviewforge:latest
PI_VERSION=0.79.1
CONTAINER_NAME=
ARTIFACT_PATH=
REVIEW_ARTIFACT_VOLUME_NAME=reviewforge-artifacts
