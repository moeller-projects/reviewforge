# Test image for the Python-only PR reviewer codebase.
FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONPATH=/app/src

WORKDIR /app

RUN pip install --no-cache-dir pytest pytest-cov pydantic

# Source layout
COPY src/ ./src/
COPY scripts/ ./scripts/
COPY tests/ ./tests/
COPY pytest.ini ./pytest.ini

# PowerShell wrappers live at the repo root. The structural tests in
# tests/test_cli.py::TestPowerShellWrapperStructure read these files
# by relative path, so they must be present at the test root too.
# COPY common.psm1 ./common.psm1
# COPY run.ps1 ./run.ps1
# COPY run-open-prs.ps1 ./run-open-prs.ps1
# COPY run-local.ps1 ./run-local.ps1
# COPY build.ps1 ./build.ps1

CMD ["python", "-m", "pytest", "--cov=reviewforge", "--cov-report=term-missing"]

